{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-30T23:15:08.866Z"
  },
  "env": {
    "OPENAI_API_KEY": "<set on gateway host only; do not commit real keys>"
  },
  "wizard": {
    "lastRunAt": "2026-03-30T17:40:46.764Z",
    "lastRunVersion": "2026.3.13",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "update": {
    "checkOnStart": false
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  },
  "auth": {
    "profiles": {
      "kilocode:default": {
        "provider": "kilocode",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "kilocode/kilo-auto/balanced"
      },
      "workspace": "/root/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "kmbl-image-gen",
        "name": "KMBL Image Generator",
        "workspace": "~/.openclaw/workspace-kmbl-image-gen",
        "skills": [
          "openai-image-gen"
        ],
        "tools": {
          "deny": []
        }
      },
      {
        "id": "kmbl-planner",
        "name": "KMBL Planner",
        "workspace": "~/.openclaw/workspace-kmbl-planner",
        "skills": [
          "mcporter"
        ],
        "tools": {
          "deny": []
        }
      },
      {
        "id": "kmbl-generator",
        "name": "KMBL Generator",
        "workspace": "~/.openclaw/workspace-kmbl-generator",
        "skills": [
          "mcporter"
        ],
        "tools": {
          "deny": []
        }
      },
      {
        "id": "kmbl-evaluator",
        "name": "KMBL Evaluator",
        "workspace": "~/.openclaw/workspace-kmbl-evaluator",
        "skills": [
          "mcporter"
        ],
        "tools": {
          "deny": []
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": true,
      "allow": [
        ""
      ]
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "<discord-bot-token>",
      "groupPolicy": "allowlist",
      "streaming": "off",
      "dmPolicy": "pairing",
      "allowFrom": [],
      "dm": {
        "policy": "pairing",
        "allowFrom": []
      }
    },
    "streamchat": {
      "apiKey": "<streamchat-api-key>",
      "botUserId": "<streamchat-bot-user-id>",
      "botUserToken": "<streamchat-bot-user-jwt>",
      "botUserName": "KiloClaw",
      "enabled": true
    }
  },
  "gateway": {
    "port": 3001,
    "mode": "local",
    "bind": "tailnet",
    "controlUi": {
      "allowedOrigins": [
        "https://claw.kilosessions.ai",
        "https://kilo.ai",
        "https://www.kilo.ai"
      ],
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "<gateway-control-ui-token>"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "skills": {
    "entries": {
      "openai-image-gen": {
        "enabled": true,
        "apiKey": "<optional-per-skill-openai-key-or-omit>"
      }
    }
  },
  "plugins": {
    "load": {
      "paths": [
        "/usr/local/lib/node_modules/@wunderchat/openclaw-channel-streamchat"
      ]
    },
    "entries": {
      "discord": {
        "enabled": true
      },
      "streamchat": {
        "enabled": true
      }
    }
  }
}
