# Copy to `.env.local` in this directory (Next.js loads it automatically).
# Do not commit `.env.local`.

# Orchestrator base URL — must match where uvicorn is listening (host + port).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8010

# Optional later — only if the browser talks to Supabase directly (e.g. Realtime, client reads).
# Prefer server-side / orchestrator access for secrets; use anon key only with RLS policies.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
