# =============================================================================
# KMBL — copy to repo root as `.env` (or use `services/orchestrator/.env` for Python only).
# The orchestrator loads `.env` from its working directory and `../../.env` (repo root).
# =============================================================================

# --- Orchestrator (FastAPI / LangGraph) ---
# On Windows, if binding fails (WinError 10013), prefer 127.0.0.1 and a free port.
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
# true | false — set false if uvicorn --reload misbehaves (OneDrive / file watchers).
ORCHESTRATOR_RELOAD=true

# --- Supabase (platform) — v1: supabase-py from the orchestrator is fine ---
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server-only. Never expose to the browser or commit. Used by the orchestrator for inserts/reads.
SUPABASE_SERVICE_ROLE_KEY=
# Optional but useful: direct Postgres URI (migrations, psql, or future SQLAlchemy).
# Dashboard → Project Settings → Database → Connection string (URI), or use pooler URL.
SUPABASE_DB_URL=

# --- KiloClaw (wire after DB-backed runs work; stub is fine until then) ---
KILOCLAW_BASE_URL=https://kiloclaw.example.invalid
KILOCLAW_API_KEY=
KILOCLAW_PLANNER_CONFIG_KEY=planner
KILOCLAW_GENERATOR_CONFIG_KEY=generator
KILOCLAW_EVALUATOR_CONFIG_KEY=evaluator

# --- Control-plane (Next.js) — prefer `apps/control-plane/.env.local` (see apps/control-plane/.env.example) ---
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
