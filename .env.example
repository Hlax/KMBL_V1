# =============================================================================
# KMBL — copy to repo root as `.env` (or use `services/orchestrator/.env` for Python only).
# The orchestrator loads `.env` from its working directory and `../../.env` (repo root).
#
# Deployment layout: Vercel (Next.js control plane) + VPS (this orchestrator) + Supabase.
# Local persisted run checklist: docs/LOCAL_MILESTONE_RUN.md
# See docs/16_DEPLOYMENT_ARCHITECTURE.md and services/orchestrator/DEPLOY.md.
# =============================================================================

# --- Orchestrator (FastAPI / LangGraph) ---
# On Windows, if binding fails (WinError 10013), prefer 127.0.0.1 and a free port.
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
# true | false — set false if uvicorn --reload misbehaves (OneDrive / file watchers).
ORCHESTRATOR_RELOAD=true
# Seconds: running graph_run rows older than this are failed on GET reconcile (0 = off).
ORCHESTRATOR_RUNNING_STALE_AFTER_SECONDS=3600
# POST /orchestrator/runs/start: max seconds for synchronous DB persist before HTTP 504 (0 = no limit).
ORCHESTRATOR_RUN_START_SYNC_TIMEOUT_SEC=120
# Optional: require this key on POST/PUT/PATCH/DELETE (X-API-Key or Authorization: Bearer). Empty = no auth.
# ORCHESTRATOR_API_KEY=
# fastapi_background (default) | external_worker (reserved — see docs/18_DURABLE_GRAPH_RUNS.md)
# ORCHESTRATOR_GRAPH_RUN_DISPATCH=fastapi_background
# true | false — background run executes only planner + persist (no generator/evaluator/staging). Local KiloClaw smoke.
ORCHESTRATOR_SMOKE_PLANNER_ONLY=false
# true | false — enable POST /orchestrator/invoke-role (dev-only direct role invoke). Production: false.
# KMBL_ORCHESTRATOR_ALLOW_DEV_ROLE_INVOKE=false
# Identity: allow synthetic DEFAULT_FALLBACK_PROFILE when DB profile is empty (dev). Production: false.
# KMBL_IDENTITY_ALLOW_FALLBACK_PROFILE=true
# Minimum IdentitySeed.confidence (0–1) for autonomous loop identity_fetch; 0 = off.
# KMBL_IDENTITY_MINIMUM_CONFIDENCE=0
# Autonomous loop: mark failed after N consecutive graph tick failures.
# KMBL_AUTONOMOUS_LOOP_MAX_CONSECUTIVE_FAILURES=5
# Default generator↔evaluator loop iterations when POST /orchestrator/runs/start omits max_iterations (1–100).
# KMBL_GRAPH_MAX_ITERATIONS_DEFAULT=10
# Mid-run replan: when true, iterate may route to planner (new build_spec) on pivot/fresh_start/stagnation — see docs/OPERATOR_LOOP_AND_IDENTITY.md
# KMBL_GRAPH_REPLAN_ON_ITERATE_ENABLED=true
# Stagnation-only replan when retry_direction is refine (0 = disable; e.g. 3)
# KMBL_GRAPH_REPLAN_STAGNATION_THRESHOLD=0
# When to persist staging_snapshot rows on stage: always | on_nomination | never (default: on_nomination)
# KMBL_STAGING_SNAPSHOT_POLICY=on_nomination
# Optional: absolute base for kmbl_session_staging.*_url fields (e.g. http://127.0.0.1:8010).
# KMBL_ORCHESTRATOR_PUBLIC_BASE_URL=
# Optional: after evaluator, HEAD/GET-probe gallery strip image URLs (can be flaky in CI; default off).
# ORCHESTRATOR_GALLERY_STRIP_PROBE_URLS=false

# --- Supabase (platform) — v1: supabase-py from the orchestrator is fine ---
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server-only. Never expose to the browser or commit. Used by the orchestrator for inserts/reads.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: Postgres URI(s) — same database; two common shapes:
# - Pooler (PgBouncer): …pooler.supabase.com:6543 — fine for many short-lived clients.
# - Direct (session): db.<project-ref>.supabase.co:5432 — prefer for migrations, DDL, long sessions, some tools.
# You may set SUPABASE_DB_URL to the pooler and DATABASE_URL to the direct URI (both valid at once).
# Dashboard → Project Settings → Database → Connection string.
SUPABASE_DB_URL=
# Optional: direct URI if you use a pooler above. Scripts read DATABASE_URL first, else SUPABASE_DB_URL.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# --- OpenClaw gateway (local or remote) ---
# Canonical env names are OPENCLAW_* . Legacy KILOCLAW_* names are still accepted (same variables).
# KMBL_ENV=development|test|production — production defaults to forbidding stub transport unless overridden.
# ALLOW_STUB_TRANSPORT=true — explicitly allow stub transport even when KMBL_ENV=production (demos/tests only).
KMBL_ENV=development
# ALLOW_STUB_TRANSPORT=
#
# Transport: auto | stub | http | openclaw_cli
# - auto: http when OPENCLAW_API_KEY is set OR (development) OPENCLAW_BASE_URL is loopback (e.g. local gateway);
#   else stub when ALLOW_STUB_TRANSPORT / KMBL_ENV allows
# - http: POST {OPENCLAW_BASE_URL}{OPENCLAW_INVOKE_PATH} OpenAI chat completions (default /v1/chat/completions).
#   Gateway routes agents via model=openclaw:<agent_id>. See docs/15_KILOCLAW_SYNC_ADAPTER.md for proxy notes.
# - openclaw_cli: run `openclaw agent --json` on the same machine as the orchestrator
#
# Local OpenClaw gateway default (smoke / dev):
OPENCLAW_TRANSPORT=auto
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_INVOKE_PATH=/v1/chat/completions
# OpenAI `user` field sent with chat completions (session stability on the gateway).
# The orchestrator appends `:{thread_id}` from each role payload when present.
OPENCLAW_CHAT_COMPLETIONS_USER=kmbl-orchestrator
# HTTP auth: copy `gateway.auth.token` from OpenClaw config. Optional for loopback smoke; required for non-loopback URLs.
# Orchestrator sends `Authorization: Bearer` and `x-kiloclaw-proxy-token` when a token is set.
OPENCLAW_API_KEY=
OPENCLAW_HTTP_CONNECT_TIMEOUT_SEC=30
OPENCLAW_HTTP_READ_TIMEOUT_SEC=300
# Orchestrator HTTP transport: max_tokens per role (defaults are 8192 for planner/generator/evaluator in code).
# OPENCLAW_CHAT_MAX_TOKENS_PLANNER=8192
# OPENCLAW_CHAT_MAX_TOKENS_GENERATOR=8192
# OPENCLAW_CHAT_MAX_TOKENS_EVALUATOR=8192
# Standalone script only (not read by the orchestrator process): smoke_openclaw_direct_post_generator.py
# OPENCLAW_SMOKE_GENERATOR_MAX_TOKENS=4096
# smoke_openclaw_loopback_e2e.py — poll until completed/failed (default 1800s; raise for slow local Ollama)
# SMOKE_DEADLINE_SEC=1800
# Agent ids (must match OpenClaw agents.list)
OPENCLAW_PLANNER_CONFIG_KEY=kmbl-planner
OPENCLAW_GENERATOR_CONFIG_KEY=kmbl-generator
OPENCLAW_EVALUATOR_CONFIG_KEY=kmbl-evaluator
OPENCLAW_GENERATOR_OPENAI_IMAGE_CONFIG_KEY=kmbl-image-gen
# KMB_OPENAI_IMAGE_HOURLY_TOKEN_CAP=1500000
# KMB_OPENAI_IMAGE_ROUTE_ESTIMATED_TOKENS_PER_INVOCATION=12000
OPENCLAW_OPENCLAW_EXECUTABLE=openclaw
OPENCLAW_OPENCLAW_TIMEOUT_SEC=300
# Local smoke: omit evaluator preview_url (contract/payload review only; nudges agents away from browser tooling).
# KMBL_SMOKE_CONTRACT_EVALUATOR=true

# --- Legacy: orchestrator direct OpenAI Images API (disabled; use kmbl-image-gen + gateway OPENAI_API_KEY) ---
# KMB_LEGACY_ORCHESTRATOR_OPENAI_IMAGES=false
# KMB_IMAGE_GENERATION_ENABLED=false
# KMB_OPENAI_IMAGE_API_KEY=
# KMB_OPENAI_IMAGE_MODEL=dall-e-3
# KMB_MAX_IMAGES_PER_GRAPH_RUN=4

# --- Control-plane (Next.js) — prefer `apps/control-plane/.env.local` (see apps/control-plane/.env.example) ---
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
