# Copy to `.env.local` in this directory. Next.js loads `.env.local` automatically.
# Do not commit `.env.local`.

# --- Orchestrator (local dev) ---
# Base URL of the FastAPI app — no path suffix. For same-machine dev:
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:8010
# Match ORCHESTRATOR_PORT in repo-root `.env.local` (e.g. 8010).

# --- Optional: Supabase in the browser ---
# Prefer server-side calls via orchestrator for secrets. If you enable client Supabase,
# use the anon key only with RLS; never put the service role key here.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: pin gallery strip experiment on homepage ---
# When set, operator home fetches this staging snapshot and renders ui_gallery_strip_v1
# from metadata.working_state_patch (read-only; rollback = new staging snapshot).
# NEXT_PUBLIC_UI_GALLERY_STAGING_SNAPSHOT_ID=
