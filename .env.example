# =============================================================================
# KMBL — copy to repo root as `.env` (or use `services/orchestrator/.env` for Python only).
# The orchestrator loads `.env` from its working directory and `../../.env` (repo root).
#
# Deployment layout: Vercel (Next.js control plane) + VPS (this orchestrator) + Supabase.
# Local persisted run checklist: docs/LOCAL_MILESTONE_RUN.md
# See docs/16_DEPLOYMENT_ARCHITECTURE.md and services/orchestrator/DEPLOY.md.
# =============================================================================

# --- Orchestrator (FastAPI / LangGraph) ---
# On Windows, if binding fails (WinError 10013), prefer 127.0.0.1 and a free port.
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
# true | false — set false if uvicorn --reload misbehaves (OneDrive / file watchers).
ORCHESTRATOR_RELOAD=true
# Seconds: running graph_run rows older than this are failed on GET reconcile (0 = off).
ORCHESTRATOR_RUNNING_STALE_AFTER_SECONDS=3600
# POST /orchestrator/runs/start: max seconds for synchronous DB persist before HTTP 504 (0 = no limit).
ORCHESTRATOR_RUN_START_SYNC_TIMEOUT_SEC=120
# true | false — background run executes only planner + persist (no generator/evaluator/staging). Local KiloClaw smoke.
ORCHESTRATOR_SMOKE_PLANNER_ONLY=false
# Optional: after evaluator, HEAD/GET-probe gallery strip image URLs (can be flaky in CI; default off).
# ORCHESTRATOR_GALLERY_STRIP_PROBE_URLS=false

# --- Supabase (platform) — v1: supabase-py from the orchestrator is fine ---
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Server-only. Never expose to the browser or commit. Used by the orchestrator for inserts/reads.
SUPABASE_SERVICE_ROLE_KEY=
# Optional but useful: direct Postgres URI (migrations, psql, or future SQLAlchemy).
# Dashboard → Project Settings → Database → Connection string (URI), or use pooler URL.
SUPABASE_DB_URL=

# --- KiloClaw / OpenClaw ---
# Transport: auto | stub | http | openclaw_cli
# - auto: http if KILOCLAW_API_KEY set, else stub
# - http: POST {KILOCLAW_BASE_URL}{KILOCLAW_INVOKE_PATH} OpenAI chat completions (default /v1/chat/completions).
#   Gateway routes agents via model=openclaw:<agent_id>. Legacy proxy POST /v1/invoke is optional — see docs/15_KILOCLAW_SYNC_ADAPTER.md.
# - openclaw_cli: run `openclaw agent --json` on the same machine as the orchestrator
#
# Connectivity (pick one base URL — no code change, only this env):
# - Tailnet (preferred): You need ONE Tailscale account at https://tailscale.com (free tier is fine). Install
#   Tailscale on both the gateway host and the machine running this orchestrator; join the same tailnet
#   (`tailscale up` or auth key from admin console). Then use the gateway’s Tailscale IP or MagicDNS name:
#     KILOCLAW_BASE_URL=http://100.x.x.x:3001
#     or  http://your-gateway-host.your-tailnet.ts.net:3001
#   Port must match the gateway (often 3001). HTTP over tailnet is normal — Tailscale encrypts the path.
#   Values come from: Tailscale admin → Machines, or `tailscale status` / `tailscale ip -4` on the gateway.
# - Public fallback: when the orchestrator cannot join Tailscale (e.g. some serverless hosts), use your HTTPS
#   URL (Tailscale Funnel, Fly public route, reverse proxy): KILOCLAW_BASE_URL=https://your-host
#
# What to ask the KiloClaw/OpenClaw side for: gateway port, bind mode, and token — not Tailscale signup.
# Tailscale account, auth keys, and machine names are yours from tailscale.com, not from an LLM agent.
KILOCLAW_TRANSPORT=auto
KILOCLAW_BASE_URL=http://127.0.0.1:3001
KILOCLAW_INVOKE_PATH=/v1/chat/completions
# OpenAI `user` field sent with chat completions (session stability on the gateway).
KILOCLAW_CHAT_COMPLETIONS_USER=kmbl-orchestrator
# HTTP auth for POST …/v1/chat/completions (must match the gateway the URL points at):
# - OpenClaw `openclaw.json` → `gateway.auth.token` (copy the string exactly into KILOCLAW_API_KEY).
# - If a controller/proxy sits in front (e.g. Fly :18789), use the same token it expects for Bearer /
#   x-kiloclaw-proxy-token — often identical to `gateway.auth.token` on the host.
# Orchestrator sends `Authorization: Bearer` and `x-kiloclaw-proxy-token` (same value).
# Note: `gateway.port` in openclaw.json is the local listener (e.g. 3001 loopback). KILOCLAW_BASE_URL must
# be the origin you actually reach (Tailscale IP:port, public host, etc.) — not necessarily that port.
KILOCLAW_API_KEY=
# httpx timeouts for chat completions (diagnosis: lower read timeout to fail fast on stalled VPS).
KILOCLAW_HTTP_CONNECT_TIMEOUT_SEC=30
KILOCLAW_HTTP_READ_TIMEOUT_SEC=300
# Agent ids (must match OpenClaw agents.list), e.g. kmbl-planner
KILOCLAW_PLANNER_CONFIG_KEY=kmbl-planner
KILOCLAW_GENERATOR_CONFIG_KEY=kmbl-generator
KILOCLAW_EVALUATOR_CONFIG_KEY=kmbl-evaluator
# openclaw_cli only
KILOCLAW_OPENCLAW_EXECUTABLE=openclaw
KILOCLAW_OPENCLAW_TIMEOUT_SEC=300

# --- Control-plane (Next.js) — prefer `apps/control-plane/.env.local` (see apps/control-plane/.env.example) ---
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
